{
  "name": "octarine-engine",
  "version": "0.1.0",
  "dependencies": [
    {
      "name": "glm",
      "version>=": "1.0.1#3"
    },
    {
      "name": "imgui",
      "features": [
        "sdl3-binding",
        "sdl3-renderer-binding"
      ],
      "version>=": "1.91.8"
    },
    {
      "name": "lua",
      "version>=": "5.4.7"
    },
    {
      "name": "sdl3",
      "version>=": "3.2.14"
    },
    {
      "name": "sdl3",
      "features": [
        "x11",
        "wayland"
      ],
      "platform": "linux"
    },
    {
      "name": "sdl3-image",
      "features": [
        "jpeg",
        "png"
      ],
      "version>=": "3.2.4"
    },
    {
      "name": "sdl3-mixer",
      "version>=": "3.2.0"
    },
    {
      "name": "sdl3-ttf",
      "version>=": "3.2.2"
    },
    {
      "name": "sol2",
      "version>=": "3.5.0"
    },
    {
      "name": "spdlog",
      "version>=": "1.15.3"
    }
  ]
}
